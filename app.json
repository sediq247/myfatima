{
  "expo": {
    "name": "MyFatima",
    "slug": "myfatima",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "cover",
      "backgroundColor": "#1a0b2e"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.myfatima.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1a0b2e"
      },
      "package": "com.myfatima.app"
    },
    "extra": {
      "eas": {
        "projectId": "6490f0d4-0f4f-437b-bf13-81fd2c65127f"
      }
    },
    "plugins": [
      "expo-font"
    ]
  }
}
